@page
@model StronaAzure.Pages.Clients.CreateModel
@{
    ViewData["Title"] = "Dodaj klienta";
}

<h1 class="mb-3">Nowy klient</h1>

<form method="post" class="card card-body">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Client.FirstName" class="form-label"></label>
        <input asp-for="Client.FirstName" class="form-control" />
        <span asp-validation-for="Client.FirstName" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Client.LastName" class="form-label"></label>
        <input asp-for="Client.LastName" class="form-control" />
        <span asp-validation-for="Client.LastName" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Client.Age" class="form-label"></label>
        <input asp-for="Client.Age" class="form-control" />
        <span asp-validation-for="Client.Age" class="text-danger"></span>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Zapisz</button>
        <a asp-page="Index" class="btn btn-secondary">Anuluj</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
